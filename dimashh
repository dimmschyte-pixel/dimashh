    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #00f2fe;
            --secondary: #4facfe;
            --dark: #0b0e14;
            --card: #161b22;
            --text: #ffffff;
            --spotify-green: #1DB954;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }
        
        body { 
            background-color: var(--dark); 
            color: var(--text); 
            scroll-behavior: smooth;
        }

        /* --- Hero Section --- */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: radial-gradient(circle at center, #1e293b 0%, #0b0e14 100%);
            padding: 20px;
        }

        .profile-img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 4px solid var(--primary);
            margin-bottom: 20px;
            object-fit: cover;
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.3);
        }

        h1 { font-size: 3.5rem; margin-bottom: 10px; background: linear-gradient(to right, var(--primary), var(--secondary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        /* --- Social Icons --- */
        .social-links {
            display: flex;
            gap: 25px;
            margin: 25px 0;
        }

        .social-links a {
            color: var(--text);
            font-size: 2rem;
            transition: 0.3s;
        }

        .fa-instagram:hover { color: #E1306C; transform: scale(1.2); }
        .fa-tiktok:hover { color: #ff0050; transform: scale(1.2); }
        .fa-spotify:hover { color: var(--spotify-green); transform: scale(1.2); }

        /* --- Main Container --- */
        .container { max-width: 900px; margin: 0 auto; padding: 50px 20px; }

        .section-title {
            text-align: center;
            margin-bottom: 40px;
            font-size: 2rem;
            position: relative;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 50px;
            height: 4px;
            background: var(--primary);
            margin: 10px auto;
        }

        /* --- Spotify Section --- */
        .spotify-container {
            background: var(--card);
            padding: 20px;
            border-radius: 20px;
            border: 1px solid #30363d;
        }

        iframe { border-radius: 12px; }

        /* --- Footer --- */
        footer {
            text-align: center;
            padding: 40px;
            opacity: 0.6;
            font-size: 0.9rem;
        }

        /* Mobile Optimization */
        @media (max-width: 600px) {
            h1 { font-size: 2.5rem; }
        }
    </style>
